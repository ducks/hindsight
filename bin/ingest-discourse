#!/usr/bin/env python3
"""
Ingest incidents from Discourse via MCP.

Must be run from Claude Code context with discourse MCP server connected.

Usage:
    bin/ingest-discourse --base-url https://discourse.example.com --tag incident --limit 50
"""

import argparse
import sys
from pathlib import Path

# Add src to path
sys.path.insert(0, str(Path(__file__).parent.parent / "src"))

from hindsight.ingest.discourse import DiscourseIngester


def main():
    parser = argparse.ArgumentParser(description="Ingest Discourse incidents via MCP")
    parser.add_argument("--base-url", required=True, help="Discourse base URL")
    parser.add_argument("--tag", default="incident", help="Tag to filter (default: incident)")
    parser.add_argument("--limit", type=int, default=50, help="Max incidents to fetch")
    parser.add_argument("--output", default="data/incidents", help="Output directory")

    args = parser.parse_args()

    print(f"This script requires Claude Code with MCP access to {args.base_url}")
    print(f"Fetching topics tagged '{args.tag}' (limit: {args.limit})")
    print()
    print("Claude Code agent should:")
    print(f"1. Call discourse_filter_topics(filter='tag:{args.tag}', per_page={args.limit})")
    print("2. For each topic, call discourse_read_topic(topic_id=X)")
    print(f"3. Pass data to DiscourseIngester with base_url={args.base_url}")
    print()
    print("Run this from Claude Code!")


if __name__ == '__main__':
    main()
