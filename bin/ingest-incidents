#!/usr/bin/env ruby
# frozen_string_literal: true

# Ingest incident topics from dev.discourse.org via MCP
#
# Usage:
#   bin/ingest-incidents [--since YYYY-MM-DD] [--limit N]
#
# Requires: Claude Code with discourse-dev MCP server configured

require "json"
require "fileutils"
require "optparse"

options = {
  since: nil,
  limit: 100,
  output_dir: File.expand_path("../data/raw", __dir__)
}

OptionParser.new do |opts|
  opts.banner = "Usage: bin/ingest-incidents [options]"

  opts.on("--since DATE", "Only fetch incidents since this date (YYYY-MM-DD)") do |date|
    options[:since] = date
  end

  opts.on("--limit N", Integer, "Max number of topics to fetch (default: 100)") do |n|
    options[:limit] = n
  end

  opts.on("--output DIR", "Output directory for raw incident data") do |dir|
    options[:output_dir] = dir
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end.parse!

FileUtils.mkdir_p(options[:output_dir])

puts "Hindsight Incident Ingestion"
puts "=" * 50
puts "Fetching incidents from dev.discourse.org via MCP..."
puts "Output: #{options[:output_dir]}"
puts "Limit: #{options[:limit]}"
puts "Since: #{options[:since] || 'all time'}"
puts

# Tags to search for incident-related topics
INCIDENT_TAGS = %w[
  incident
  alert
  outage
  degraded-performance
  postmortem
]

puts "Searching for topics with tags: #{INCIDENT_TAGS.join(', ')}"
puts
puts "NOTE: This script is meant to be run via Claude Code with MCP access."
puts "It will call the discourse-dev MCP server to fetch topics."
puts
puts "If you're running this directly, you'll need to implement MCP client calls."
puts
puts "Example MCP calls needed:"
puts "  - mcp__discourse-dev__discourse_filter_topics(tag: 'incident', limit: #{options[:limit]})"
puts "  - mcp__discourse-dev__discourse_read_topic(topic_id: X, post_limit: 50)"
puts
puts "Run this via Claude Code with: 'ingest incident topics from dev.discourse.org'"
