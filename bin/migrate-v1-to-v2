#!/usr/bin/env ruby
# frozen_string_literal: true

# Migrates v1 incident data (topic-*.json) to v2 format (YYYYMMDD-*.json)
# with structured timelines, failure patterns, and searchable metadata

require 'json'
require 'time'
require 'fileutils'

SOURCE_DIR = File.expand_path('../data/raw', __dir__)
DEST_DIR = File.expand_path('../data/incidents', __dir__)

FileUtils.mkdir_p(DEST_DIR)

def extract_timeline(raw_content)
  # Extract timestamped events from raw content
  events = []

  # Look for time patterns like "12:34", "12:34 PM", timestamps, etc.
  raw_content.scan(/(?:^|\n)(\d{1,2}:\d{2}(?:\s*(?:AM|PM|am|pm))?)[:\s-]+(.+?)(?=\n|$)/m) do |time, description|
    events << {
      timestamp: time.strip,
      description: description.strip.lines.first&.strip,
      actor: nil # Could extract from context
    }
  end

  events
end

def extract_commands(raw_content)
  # Extract shell commands from content
  commands = []

  # Look for command-like patterns
  raw_content.scan(/(?:^|\n)[\$#]\s*(.+?)(?=\n|$)/) do |cmd|
    commands << cmd.first.strip
  end

  commands.uniq
end

def extract_keywords(v1_data)
  keywords = []

  # Add alert type
  keywords << v1_data['alert_type'] if v1_data['alert_type']

  # Add affected systems
  keywords.concat(v1_data['affected_systems']) if v1_data['affected_systems']

  # Extract from symptoms
  if v1_data['symptoms']
    symptoms_text = v1_data['symptoms'].is_a?(Array) ? v1_data['symptoms'].join(' ') : v1_data['symptoms'].to_s
    keywords << 'high-error-rate' if symptoms_text.match?(/high.*error|error.*rate/i)
    keywords << 'timeout' if symptoms_text.match?(/timeout/i)
    keywords << '5xx' if symptoms_text.match?(/5\d{2}|500|502|503/i)
    keywords << 'memory' if symptoms_text.match?(/memory|oom/i)
    keywords << 'disk' if symptoms_text.match?(/disk|space/i)
    keywords << 'network' if symptoms_text.match?(/network|connection/i)
  end

  keywords.uniq.compact
end

def extract_error_patterns(v1_data)
  patterns = []

  content = [v1_data['symptoms'], v1_data['raw_content']].compact.join("\n")

  # Common error patterns
  content.scan(/(?:error|exception|failed):\s*(.+?)(?=\n|$)/i) do |match|
    patterns << match.first.strip
  end

  patterns.uniq.first(5) # Keep top 5
end

def classify_failure(v1_data)
  symptoms = v1_data['symptoms']
  symptoms = symptoms.is_a?(Array) ? symptoms.join(' ') : symptoms.to_s
  root_cause = v1_data['root_cause'].to_s
  content = "#{symptoms} #{root_cause}".downcase

  return 'hardware' if content.match?(/nic|driver|hardware|disk|raid/)
  return 'network' if content.match?(/network|bgp|routing|dns/)
  return 'resource-exhaustion' if content.match?(/memory|oom|disk.*full|space/)
  return 'deployment' if content.match?(/deploy|release|rollout/)
  return 'configuration' if content.match?(/config|setting|env.*var/)
  return 'external' if content.match?(/ddos|attack|abuse/)
  return 'application' if content.match?(/bug|code|logic/)

  'unknown'
end

def migrate_incident(v1_file)
  v1_data = JSON.parse(File.read(v1_file))

  # Parse date from created_at
  created_at = Time.parse(v1_data['created_at'])
  date_prefix = created_at.strftime('%Y%m%d')

  # Generate filename: YYYYMMDD-topic-id.json
  filename = "#{date_prefix}-#{v1_data['topic_id']}.json"

  # Build v2 structure
  v2_data = {
    version: 2,
    metadata: {
      topic_id: v1_data['topic_id'],
      url: v1_data['url'],
      title: v1_data['title'],
      created_at: v1_data['created_at'],
      severity: nil, # Not in v1 data
      alert_type: v1_data['alert_type'],
      affected_systems: v1_data['affected_systems'] || []
    },

    timeline: {
      detection: created_at.utc.iso8601,
      investigation_start: created_at.utc.iso8601,
      root_cause_identified: nil, # Could extract from content
      resolution_start: nil,
      resolution_complete: nil,
      events: extract_timeline(v1_data['raw_content'] || '')
    },

    investigation: {
      symptoms: v1_data['symptoms'],
      steps: v1_data['investigation_steps'] || [],
      commands_run: extract_commands(v1_data['raw_content'] || ''),
      tools_used: [],
      dead_ends: []
    },

    resolution: {
      root_cause: v1_data['root_cause'],
      fix_applied: v1_data['resolution'],
      preventive_measures: []
    },

    failure_patterns: [
      {
        category: classify_failure(v1_data),
        failure_mode: v1_data['root_cause'],
        triggers: [],
        playbook_ref: nil
      }
    ],

    impact: {
      duration_minutes: v1_data['duration'],
      affected_users: nil,
      service_degradation: nil
    },

    searchable: {
      keywords: extract_keywords(v1_data),
      error_patterns: extract_error_patterns(v1_data),
      similar_incidents: []
    },

    raw: {
      original_content: v1_data['raw_content']
    }
  }

  dest_path = File.join(DEST_DIR, filename)
  File.write(dest_path, JSON.pretty_generate(v2_data))

  puts "✓ Migrated #{File.basename(v1_file)} → #{filename}"
  filename
end

# Main migration
v1_files = Dir.glob(File.join(SOURCE_DIR, 'topic-*.json')).sort

puts "Migrating #{v1_files.length} incidents from v1 to v2..."
puts

migrated = v1_files.map { |file| migrate_incident(file) }

puts
puts "Migration complete! #{migrated.length} incidents written to #{DEST_DIR}"
puts
puts "Files are now named with date-ver: YYYYMMDD-topic-id.json"
